{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext"],
    "declaration": true,
    "outDir": "dist",
    "allowJs": true,
    "resolveJsonModule": true,
    "strict": true,
    "noEmit": false,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "strictNullChecks": true
  },
  "include": ["src", "**/*.ts"],
  "exclude": ["node_modules/", "dist", "**/*.js", "openapi/generate/"]
}
